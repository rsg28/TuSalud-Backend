# =============================================================================
# TuSalud — Backend env example
# Copia este archivo a `.env` y completa los valores reales.
# =============================================================================

# --- Base de datos -----------------------------------------------------------
DB_HOST=tusaluddb.cwt2imwkyevt.us-east-1.rds.amazonaws.com
DB_USER=admin
DB_PASSWORD=
DB_NAME=tusalud
DB_PORT=3306

# --- Servidor ---------------------------------------------------------------
PORT=3000
NODE_ENV=production

# --- JWT --------------------------------------------------------------------
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- CORS / Frontend --------------------------------------------------------
CORS_ORIGIN=http://localhost:8081
FRONTEND_URL=https://tu-salud.xyz

# --- Resend (emails) --------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=TuSalud <noreply@send.tu-salud.xyz>

# --- Modo dev (deshabilita verificación JWT) --------------------------------
DISABLE_JWT_AUTH=true

# =============================================================================
# AWS S3 — Respaldo de archivos subidos (opcional pero recomendado)
# =============================================================================
# Si AWS_S3_BUCKET o AWS_REGION están vacíos, el respaldo a S3 queda
# DESACTIVADO: las filas en archivos_subidos se crean igual (con sha256 +
# tamaño + estado=ERROR_S3) pero el binario no se sube.
#
# Si la app corre en EC2 con un IAM role attached que ya tiene permisos
# s3:PutObject sobre el bucket, puedes dejar AWS_ACCESS_KEY_ID y
# AWS_SECRET_ACCESS_KEY VACÍOS — el SDK usa el role automáticamente.
#
# Para crear bucket + IAM user, ver scripts/README_S3.md.

AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_S3_KEY_PREFIX=uploads/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# =============================================================================
# WhatsApp — Aprobación/rechazo de cotizaciones por mensaje
# =============================================================================
# Cuando un cliente sube un pedido con cotización, el sistema envía un Excel
# con el detalle al WhatsApp del vendedor asignado (o al manager fallback).
# El vendedor responde con palabras clave (APROBAR / RECHAZAR + motivo) y el
# bot actualiza el estado de la cotización en BD.
#
# Si WHATSAPP_PROVIDER queda en "null" o vacío, NO se envía nada al exterior:
# las filas en `whatsapp_aprobaciones` no se crean y el flujo sigue funcionando
# como antes (las cotizaciones se aprueban/rechazan solo desde la app).
#
# Proveedor recomendado: twilio (sandbox gratis para probar de inmediato).
# Pasos para activarlo:
#   1. Crear cuenta en https://www.twilio.com — copia ACCOUNT SID y AUTH TOKEN.
#   2. En Console → Messaging → Try it out → Send a WhatsApp message: activa
#      el sandbox (te da el número emisor con prefijo "whatsapp:+1...").
#   3. En el sandbox, configura "When a message comes in" con la URL pública
#      https://<TU_DOMINIO>/api/whatsapp/webhook (POST).
#   4. Setea las variables abajo y reinicia el backend.
#   5. Cada teléfono que reciba o envíe mensajes en el sandbox debe haberse
#      "registrado" enviando un código (ej. "join orange-tiger") al número.

WHATSAPP_PROVIDER=null
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox por defecto de Twilio (cámbialo por tu número aprobado en prod):
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Número emisor de SMS (formato E.164, sin prefijo "whatsapp:"). En Twilio
# tienes que comprar/aprobar un número SMS distinto del sandbox WhatsApp.
# Si lo dejas vacío, el fallback a SMS queda deshabilitado y los WhatsApps
# que no se entreguen simplemente quedan registrados como "undelivered".
TWILIO_SMS_FROM=

# URL pública del backend (sin slash final). Se usa para:
#   - construir la URL absoluta del XLSX adjunto que Twilio descargará.
#   - construir la URL del StatusCallback que Twilio hitea con cada update.
#   - verificar la firma X-Twilio-Signature del webhook + status-callback.
WHATSAPP_PUBLIC_BASE_URL=

# Si el pedido no tiene vendedor asignado o su usuario no tiene teléfono,
# enviamos la solicitud a este número (formato +51..., sin "whatsapp:").
# Déjalo vacío para no usar fallback (la cotización simplemente no se envía).
WHATSAPP_MANAGER_FALLBACK_PHONE=

# Fallback automático WhatsApp → SMS cuando Twilio reporta que el WhatsApp
# no se entregó (status `undelivered` o `failed`). Habilitado por defecto
# si TWILIO_SMS_FROM está seteado. Ponlo en "false" para forzar off.
WHATSAPP_SMS_FALLBACK_ENABLED=true
