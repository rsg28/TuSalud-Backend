# =============================================================================
# TuSalud — Backend env example
# Copia este archivo a `.env` y completa los valores reales.
# =============================================================================

# --- Base de datos -----------------------------------------------------------
DB_HOST=tusaluddb.cwt2imwkyevt.us-east-1.rds.amazonaws.com
DB_USER=admin
DB_PASSWORD=
DB_NAME=tusalud
DB_PORT=3306

# --- Servidor ---------------------------------------------------------------
PORT=3000
NODE_ENV=production

# --- JWT --------------------------------------------------------------------
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- CORS / Frontend --------------------------------------------------------
CORS_ORIGIN=http://localhost:8081
FRONTEND_URL=https://tu-salud.xyz

# --- Resend (emails) --------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=TuSalud <noreply@send.tu-salud.xyz>

# --- Modo dev (deshabilita verificación JWT) --------------------------------
DISABLE_JWT_AUTH=true

# =============================================================================
# AWS S3 — Respaldo de archivos subidos (opcional pero recomendado)
# =============================================================================
# Si AWS_S3_BUCKET o AWS_REGION están vacíos, el respaldo a S3 queda
# DESACTIVADO: las filas en archivos_subidos se crean igual (con sha256 +
# tamaño + estado=ERROR_S3) pero el binario no se sube.
#
# Si la app corre en EC2 con un IAM role attached que ya tiene permisos
# s3:PutObject sobre el bucket, puedes dejar AWS_ACCESS_KEY_ID y
# AWS_SECRET_ACCESS_KEY VACÍOS — el SDK usa el role automáticamente.
#
# Para crear bucket + IAM user, ver scripts/README_S3.md.

AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_S3_KEY_PREFIX=uploads/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# =============================================================================
# WhatsApp — Aprobación/rechazo de cotizaciones por mensaje
# =============================================================================
# Cuando un cliente sube un pedido con cotización, el sistema envía un Excel
# con el detalle al WhatsApp del vendedor asignado (o al manager fallback).
# El vendedor responde con palabras clave (APROBAR / RECHAZAR + motivo) y el
# bot actualiza el estado de la cotización en BD.
#
# Si WHATSAPP_PROVIDER queda en "null" o vacío, NO se envía nada al exterior:
# las filas en `whatsapp_aprobaciones` no se crean y el flujo sigue funcionando
# como antes (las cotizaciones se aprueban/rechazan solo desde la app).
#
# Proveedores soportados:
#   - meta    → WhatsApp Cloud API directa de Meta (recomendado producción).
#   - twilio  → Twilio Programmable Messaging (sandbox + SMS fallback).
#   - null    → no envía nada (modo desarrollo). Las cotizaciones siguen
#               funcionando sin notificación externa.
#
# Cómo elegir:
#   * Quieres lo más barato a escala y oficial → meta.
#   * Quieres también enviar SMS como fallback de WhatsApp → twilio (o
#     mantener provider=meta y sumar Twilio solo para SMS en otra integración).
#   * No quieres mandar nada todavía → null.
WHATSAPP_PROVIDER=null

# URL pública del backend (sin slash final). Sirve para los DOS proveedores:
#   - construye la URL absoluta del XLSX adjunto que el proveedor descargará.
#   - arma el StatusCallback (Twilio) y la URL pública del webhook (Meta).
WHATSAPP_PUBLIC_BASE_URL=

# Si el pedido no tiene vendedor asignado o su usuario no tiene teléfono,
# enviamos la solicitud a este número (formato +51..., +1..., etc.).
# Déjalo vacío para no usar fallback (la cotización simplemente no se envía).
WHATSAPP_MANAGER_FALLBACK_PHONE=

# -----------------------------------------------------------------------------
# WhatsApp Cloud API (Meta) — provider="meta"
# -----------------------------------------------------------------------------
# Pasos para activarlo:
#   1. Crear app en https://developers.facebook.com → tipo "Business" →
#      Agregar producto "WhatsApp".
#   2. En "WhatsApp → API Setup":
#        - Copiar el TEMPORARY ACCESS TOKEN (24h) o generar uno permanente
#          desde "System Users" en Business Manager.
#        - Copiar el PHONE NUMBER ID del número de prueba (o el productivo
#          tras registrar un número propio).
#        - Agregar los números de destinatarios verificados.
#   3. En "Webhooks":
#        - Callback URL: https://<TU_DOMINIO>/api/whatsapp/webhook
#        - Verify token: el valor que pongas en WHATSAPP_WEBHOOK_VERIFY_TOKEN.
#        - Suscribirse a los campos: messages, message_template_status_update.
#   4. En "App Settings → Basic" copiar el APP SECRET → WHATSAPP_APP_SECRET.
#   5. (Opcional) Crear plantilla en WhatsApp Manager con el nombre que pongas
#      en WHATSAPP_TEMPLATE_NUEVA_COTIZACION, con 5 variables {{1}}..{{5}}:
#      número de cotización, empresa, número de pedido, ítems, total.

# El "Phone Number ID" NO es el teléfono, es el id que Meta asigna al número.
WHATSAPP_PHONE_NUMBER_ID=

# Token de acceso (largo, empieza por EAA...). Permanente recomendado.
WHATSAPP_ACCESS_TOKEN=

# Verificación del handshake del webhook. Inventa una cadena fuerte y pega la
# misma en Meta Webhooks → Verify token.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# App Secret (Settings → Basic). Se usa para verificar la firma HMAC-SHA256
# del header X-Hub-Signature-256 en cada webhook entrante.
WHATSAPP_APP_SECRET=

# Versión de la Graph API (opcional; por defecto v20.0).
META_GRAPH_API_VERSION=v20.0

# Plantilla para el PRIMER mensaje al vendedor (obligatoria fuera de la
# ventana de 24h). Si la dejas vacía, el backend intenta enviar texto + XLSX,
# que solo funciona en el "test number" de Meta o si el vendedor ya escribió
# al bot en las últimas 24h.
#
# Estructura sugerida del cuerpo de la plantilla (5 variables):
#   "Nueva cotización {{1}} de {{2}} para el pedido {{3}}.\n
#    Ítems: {{4}} · Total: {{5}}\n
#    Responde APROBAR o RECHAZAR para procesarla."
WHATSAPP_TEMPLATE_NUEVA_COTIZACION=
WHATSAPP_TEMPLATE_LANGUAGE=es

# -----------------------------------------------------------------------------
# Twilio — provider="twilio"
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox por defecto de Twilio (cámbialo por tu número aprobado en prod):
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Número emisor de SMS (formato E.164, sin prefijo "whatsapp:").
# Si lo dejas vacío, el fallback a SMS queda deshabilitado.
TWILIO_SMS_FROM=

# Fallback automático WhatsApp → SMS cuando Twilio reporta que el WhatsApp
# no se entregó (`undelivered`/`failed`). Solo aplica con provider=twilio.
WHATSAPP_SMS_FALLBACK_ENABLED=true
